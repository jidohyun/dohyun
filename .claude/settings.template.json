{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node {{DOHYUN_ROOT}}/dist/hooks/session-start.js"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node {{DOHYUN_ROOT}}/dist/hooks/pre-write-guard.js"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node {{DOHYUN_ROOT}}/dist/hooks/stop-continue.js"
          }
        ]
      }
    ]
  }
}
